# ===========================================
# MindEase Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# ===========================================

# Database (already configured for local dev)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# ===========================================
# SUPABASE AUTHENTICATION (Required for production)
# ===========================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===========================================
# OPTIONAL: Server-side Supabase (for admin operations)
# ===========================================
# Only needed if you're doing server-side admin tasks
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
